<Window x:Class="WpfApp3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot" 
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <TextBlock x:Name="TitleText" Text="🛡️ Cybersecurity Awareness Chatbot 🛡️" 
                       FontSize="16" FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Chat Display Area -->
        <Border Grid.Row="1" Background="#34495E" CornerRadius="5" BorderBrush="#2C3E50" BorderThickness="1">
            <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                <RichTextBox x:Name="ChatRichTextBox" 
                             Background="#34495E" 
                             Foreground="White"
                             FontFamily="Segoe UI"
                             FontSize="13"
                             BorderThickness="0"
                             IsReadOnly="True"/>
            </ScrollViewer>
        </Border>

        <!-- Input Area -->
        <Grid Grid.Row="2" Margin="0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputTextBox" 
                     Grid.Column="0"
                     Background="White"
                     Foreground="Black"
                     FontSize="13"
                     Padding="10"
                     BorderBrush="#2C3E50"
                     BorderThickness="1"
                     KeyDown="InputTextBox_KeyDown"/>

            <Button x:Name="SendButton" 
                    Grid.Column="1"
                    Content="Send"
                    Background="#2C3E50"
                    Foreground="White"
                    FontWeight="Bold"
                    Width="80"
                    Margin="10,0,0,0"
                    Click="SendButton_Click"/>
        </Grid>

        <!-- Button Bar -->
        <WrapPanel Grid.Row="3" Margin="0,10,0,0" HorizontalAlignment="Center">
            <Button x:Name="SpeakButton" 
                    Content="Speak Last Response"
                    Background="#2C3E50"
                    Foreground="White"
                    Padding="15,8"
                    Margin="5"
                    Click="SpeakButton_Click"/>
            <Button x:Name="ExportButton" 
                    Content="Export Chat"
                    Background="#2C3E50"
                    Foreground="White"
                    Padding="15,8"
                    Margin="5"
                    Click="ExportButton_Click"/>
            <Button x:Name="ClearButton" 
                    Content="Clear Chat"
                    Background="#2C3E50"
                    Foreground="White"
                    Padding="15,8"
                    Margin="5"
                    Click="ClearButton_Click"/>
        </WrapPanel>
    </Grid>
</Window>